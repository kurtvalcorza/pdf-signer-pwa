{
  "name": "pdf-signer-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Privacy-first, offline-first PWA to sign PDFs on-device (visual stamp + PKCS#12 digital signature).",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:pwa": "npm run build && playwright test --config playwright.pwa.config.ts",
    "icons": "node scripts/make-icons.mjs",
    "verify:signatures": "node scripts/verify-signatures.mjs"
  },
  "dependencies": {
    "@signpdf/placeholder-pdf-lib": "^3.2.4",
    "@signpdf/placeholder-plain": "^3.2.4",
    "@signpdf/signer-p12": "^3.2.4",
    "@signpdf/signpdf": "^3.2.4",
    "@signpdf/utils": "^3.2.4",
    "idb-keyval": "^6.2.1",
    "node-forge": "^1.3.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.11",
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.48.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "typescript-eslint": "^8.14.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^2.1.5"
  }
}
